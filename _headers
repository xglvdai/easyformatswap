# Cloudflare Pages _headers
# Apply security & caching headers to all responses.
# COOP/COEP are required so ffmpeg.wasm can use SharedArrayBuffer on the media tool page.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# Cross-origin isolation headers (enable SharedArrayBuffer for ffmpeg.wasm)
/tools/media-converter.html
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Long cache for static assets & vendored libraries
/assets/js/*
  Cache-Control: public, max-age=86400, must-revalidate

/assets/css/*
  Cache-Control: public, max-age=86400, must-revalidate

/assets/vendor/*
  Cache-Control: public, max-age=2592000, immutable
